{
  "manifest_version": 3,
  "name": "Rewards Pro: Elite v4.2",
  "version": "4.2",
  "description": "Ghost Engine v4.2 with Advanced NPA Human-Error Typing Simulation.",
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "declarativeNetRequest",
    "notifications"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "Icon/Icon.png"
  },
  "icons": {
    "16": "Icon/Icon.png",
    "48": "Icon/Icon.png",
    "128": "Icon/Icon.png"
  },
  "background": {
    "service_worker": "JS/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.bing.com/*"],
      "js": ["JS/content.js"],
      "css": ["CSS/hud.css"]
    }
  ],
  "host_permissions": [
    "https://www.bing.com/*"
  ]
}